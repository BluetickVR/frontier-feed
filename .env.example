# ==== Telegram ====
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=
# Your personal chat id — see SETUP.md for how to retrieve
TELEGRAM_CHAT_ID=

# ==== LLM providers ====
# Free tier, primary for summarize/rank/classify
GROQ_API_KEY=
# Free tier, fallback + embeddings (aistudio.google.com)
GEMINI_API_KEY=
# Optional, only if you want a paid synthesis fallback
ANTHROPIC_API_KEY=

# ==== Search ====
# For follow-up deep-dives (you already have this)
TAVILY_API_KEY=

# ==== GitHub (for webhook box) ====
# PAT with repo scope — lets webhook push reactions.jsonl back to the repo
GITHUB_TOKEN=
GITHUB_REPO=anshulpadyal/frontier-feed
